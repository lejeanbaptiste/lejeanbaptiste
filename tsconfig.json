{
  "include": ["**/*"],
  "exclude": ["node_modules"],
  "ts-node": {
    "files": true,
    "compilerOptions": {
      "lib": ["esnext"],
      "module": "commonjs",
      "target": "ESNext",
      "types": ["node", "jest", "mocha", "@testing-library/jest-dom"]
    }
  },
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "preserveWatchOutput": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@src/*": ["apps/commons/src/*"],
      "@cwrc/leafwriter": ["packages/cwrc-leafwriter/src/index.tsx"],
      "@cwrc/leafwriter/*": ["packages/cwrc-leafwriter/src/*"],
      "@cwrc/leafwriter/languageCodes": [
        "packages/cwrc-leafwriter/src/utilities/languageCodes.ts"
      ],
      "@cwrc/leafwriter-storage-service": [
        "packages/cwrc-leafwriter-storage-service/src/index.tsx"
      ],
      "@cwrc/leafwriter-storage-service/*": [
        "packages/cwrc-leafwriter-storage-service/src/*"
      ],
      "@cwrc/leafwriter-validator": [
        "packages/cwrc-leafwriter-validator/src/index.worker.ts"
      ],
      "@cwrc/leafwriter-validator/*": [
        "packages/cwrc-leafwriter-validator/src/*"
      ]
    },
    "target": "ESNext",
    "types": ["node", "jest", "mocha", "@testing-library/jest-dom", "mdx"]
  }
}
