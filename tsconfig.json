{
  "extends": "tsconfig/base.json",
  "include": ["**/*"],
  "exclude": ["node_modules"],
  "ts-node": {
    "files": true,
    "compilerOptions": {
      "lib": ["esnext"],
      "module": "commonjs",
      "target": "ESNext",
      "types": ["node", "jest", "mocha", "@testing-library/jest-dom"]
    }
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true,
    "types": ["node", "jest", "mocha", "@testing-library/jest-dom"],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  }
}
