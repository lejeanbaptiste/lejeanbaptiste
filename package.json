{
  "name": "leafwriter",
  "version": "1.0.0",
  "private": true,
  "description": "xml editing and rdf annotation using github as document store",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "license": "GPL-2.0",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "cm": "git-cz",
    "prepare": "husky",
    "test": "jest --silent --onlyChanged",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "dev": "npm run dev -w leafwriter-commons",
    "dev-worker": "npm run dev-worker -w leafwriter-commons",
    "build-commons": "npm run build -w leafwriter-commons",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@jest/types": "^29.6.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "changeset": "^0.2.6",
    "commitizen": "^4.3.1",
    "eslint": "^8.57.1",
    "eslint-config-custom": "*",
    "git-cz": "^4.9.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "shelljs": "^0.8.5",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "packageManager": "npm@11.1.0"
}
