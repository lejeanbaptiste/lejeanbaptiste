{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lejeanbaptiste/lejeanbaptiste/docs/authoritypacks-packs-index.schema.json",
  "title": "Authority Packs Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundleVersion",
    "compilePolicyVersion",
    "builtAt",
    "bundles"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "bundleVersion": {
      "type": "string",
      "minLength": 1
    },
    "compilePolicyVersion": {
      "type": "string",
      "minLength": 1
    },
    "builtAt": {
      "type": "string",
      "format": "date-time"
    },
    "defaultBundleId": {
      "type": "string",
      "enum": [
        "chinese",
        "japanese",
        "tibetan"
      ]
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/bundle"
      },
      "uniqueItems": false
    }
  },
  "$defs": {
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fileName",
        "bytes",
        "sha256"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "chinese",
            "japanese",
            "tibetan"
          ]
        },
        "fileName": {
          "type": "string",
          "pattern": "^authority-packs-(chinese|japanese|tibetan)\\.tar\\.gz$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "pathPrefix": {
          "type": "string",
          "const": "authority-packs"
        },
        "fileCount": {
          "type": "integer",
          "minimum": 0
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/file"
          }
        }
      }
    },
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
