{
  "extends": "./electron-builder.base.json",
  "linux": {
    "target": [
      "flatpak"
    ],
    "icon": "icons",
    "category": "Office",
    "syncDesktopName": true,
    "maintainer": "Daniel Patrick Morgan <daniel.morgan@college-de-france.fr>",
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*",
          "!.deps-installed"
        ]
      }
    ]
  },
  "flatpak": {
    "runtimeVersion": "25.08",
    "baseVersion": "25.08",
    "useWaylandFlags": true
  },
  "win": {
    "target": [
      "nsis"
    ]
  }
}
