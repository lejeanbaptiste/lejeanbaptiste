{
  "appId": "fr.huma-num.le-jean-baptiste",
  "productName": "Le Jean-Baptiste",
  "electronVersion": "43.1.0",
  "directories": {
    "output": "release",
    "buildResources": "../../design"
  },
  "icon": "icon",
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../../THIRD_PARTY_NOTICES.md",
      "to": "THIRD_PARTY_NOTICES.md"
    },
    {
      "from": "../../design/icon.svg",
      "to": "icon.svg"
    },
    {
      "from": "../../design/icon.png",
      "to": "icon.png"
    },
    {
      "from": "../commons/public",
      "to": "commons/public"
    },
    {
      "from": "../commons/server",
      "to": "commons/server"
    }
  ]
}
