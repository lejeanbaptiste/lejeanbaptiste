{
  "appId": "fr.huma-num.le-jean-baptiste",
  "productName": "Le Jean-Baptiste",
  "electronVersion": "43.1.0",
  "directories": {
    "output": "release",
    "buildResources": "resources/branding"
  },
  "beforeBuild": "./scripts/skip-electron-builder-deps.mjs",
  "icon": "icon",
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../../THIRD_PARTY_NOTICES.md",
      "to": "THIRD_PARTY_NOTICES.md"
    },
    {
      "from": "resources/branding",
      "to": "branding"
    },
    {
      "from": "../commons/public",
      "to": "commons/public"
    },
    {
      "from": "../commons/server",
      "to": "commons/server"
    },
    {
      "from": "resources/game-assets",
      "to": "game-assets"
    },
    {
      "from": "resources/avatar-parts",
      "to": "avatar-parts"
    }
  ]
}
