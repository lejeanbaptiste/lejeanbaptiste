{
  "extends": "./electron-builder.base.json",
  "afterPack": "./scripts/sign-mac-extra-resources.mjs",
  "publish": [
    {
      "provider": "github",
      "owner": "lejeanbaptiste",
      "repo": "lejeanbaptiste"
    }
  ],
  "mac": {
    "target": [
      "pkg",
      "zip"
    ],
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "resources/entitlements.mac.plist",
    "entitlementsInherit": "resources/entitlements.mac.plist",
    "notarize": true,
    "extraResources": [
      {
        "from": "resources/python",
        "to": "python",
        "filter": [
          "**/*",
          "!.deps-installed"
        ]
      },
      {
        "from": "resources/lemminx",
        "to": "lemminx",
        "filter": [
          "**/*",
          "!*.zip"
        ]
      }
    ]
  },
  "linux": null,
  "win": {
    "target": [
      "nsis"
    ]
  }
}
