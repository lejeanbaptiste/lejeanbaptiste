{
  "name": "crcao-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Le Jean-Baptiste — desktop XML editor",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsup",
    "icon:export": "node ../../design/export-icon.mjs",
    "brand-electron": "node scripts/brand-electron-dev.mjs",
    "predev": "npm run icon:export",
    "prestart": "npm run icon:export",
    "prebuild": "npm run icon:export",
    "prepackage": "npm run icon:export",
    "prepackage:dir": "npm run icon:export",
    "dev": "node scripts/brand-electron-dev.mjs && tsup --watch --onSuccess \"node scripts/run-electron-dev.mjs\"",
    "start": "node scripts/brand-electron-dev.mjs && node scripts/run-electron-dev.mjs",
    "package": "npm run build && electron-builder --mac",
    "package:dir": "npm run build && electron-builder --mac --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "fr.huma-num.le-jean-baptiste",
    "productName": "Le Jean-Baptiste",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../design/icon.svg",
        "to": "icon.svg"
      },
      {
        "from": "../../design/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../commons/public",
        "to": "commons/public"
      },
      {
        "from": "../commons/server",
        "to": "commons/server"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "../../design/icon.svg",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}