{
  "name": "le-jean-baptiste-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Le Jean-Baptiste — desktop XML editor",
  "author": "Daniel Patrick Morgan (CNRS)",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsup",
    "icon:export": "node ../../design/export-icon.mjs",
    "brand-electron": "node scripts/brand-electron-dev.mjs",
    "lemminx:download": "node scripts/download-lemminx.mjs",
    "notarize": "node scripts/notarize.cjs",
    "postinstall": "node scripts/download-lemminx.mjs",
    "predev": "npm run icon:export && npm run lemminx:download",
    "prestart": "npm run icon:export",
    "prebuild": "npm run icon:export",
    "prepackage": "npm run icon:export",
    "prepackage:dir": "npm run icon:export",
    "dev": "node scripts/brand-electron-dev.mjs && tsup --watch --onSuccess \"node scripts/run-electron-dev.mjs\"",
    "start": "node scripts/brand-electron-dev.mjs && node scripts/run-electron-dev.mjs",
    "package": "npm run build && electron-builder --mac",
    "package:dir": "npm run build && electron-builder --mac --dir",
    "package:pkg": "npm run build && electron-builder --mac pkg"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "fr.huma-num.le-jean-baptiste",
    "productName": "Le Jean-Baptiste",
    "electronVersion": "43.1.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../design/icon.svg",
        "to": "icon.svg"
      },
      {
        "from": "../../design/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../commons/public",
        "to": "commons/public"
      },
      {
        "from": "../commons/server",
        "to": "commons/server"
      },
      {
        "from": "resources/lemminx",
        "to": "lemminx",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "../../design/icon.png",
      "hardenedRuntime": true,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "target": [
        "pkg"
      ]
    },
    "afterSign": "scripts/notarize.cjs",
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
