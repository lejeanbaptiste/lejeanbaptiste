{
  "name": "le-jean-baptiste-desktop",
  "version": "0.0.1",
  "private": true,
  "description": "Le Jean-Baptiste — desktop XML editor",
  "author": {
    "name": "Daniel Patrick Morgan",
    "email": "daniel.morgan@college-de-france.fr"
  },
  "homepage": "https://gitlab.huma-num.fr/dmorgan1/lejeanbaptiste",
  "main": "dist/main.js",
  "build": {
    "appId": "fr.huma-num.le-jean-baptiste",
    "productName": "Le Jean-Baptiste",
    "linux": {
      "category": "Office",
      "desktopName": "le-jean-baptiste",
      "syncDesktopName": true,
      "target": [
        "deb"
      ],
      "maintainer": "Daniel Patrick Morgan <daniel.morgan@college-de-france.fr>"
    }
  },
  "scripts": {
    "build": "tsup",
    "icon:export": "node ../../design/export-icon.mjs",
    "brand-electron": "node scripts/brand-electron-dev.mjs",
    "lemminx:download": "node scripts/download-lemminx.mjs",
    "postinstall": "node scripts/download-lemminx.mjs",
    "predev": "npm run icon:export && npm run lemminx:download",
    "prestart": "npm run icon:export",
    "prebuild": "npm run icon:export",
    "prepackage": "npm run icon:export",
    "prepackage:dir": "npm run icon:export",
    "dev": "node scripts/brand-electron-dev.mjs && tsup --watch --onSuccess \"node scripts/run-electron-dev.mjs\"",
    "start": "node scripts/brand-electron-dev.mjs && node scripts/run-electron-dev.mjs",
    "package": "npm run build && electron-builder --config electron-builder.mac.json",
    "package:mac": "npm run build && electron-builder --config electron-builder.mac.json",
    "package:linux": "npm run build && electron-builder --config electron-builder.linux.json --linux deb",
    "package:dir": "npm run build && electron-builder --config electron-builder.linux.json --dir",
    "package:deb": "npm run build && electron-builder --config electron-builder.linux.json --linux deb"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0"
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
