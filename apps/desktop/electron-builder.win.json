{
  "extends": "./electron-builder.base.json",
  "publish": [
    {
      "provider": "github",
      "owner": "lejeanbaptiste",
      "repo": "lejeanbaptiste"
    }
  ],
  "artifactName": "Le-Jean-Baptiste-Setup-${version}-${arch}.${ext}",
  "extraResources": [
    {
      "from": "../../THIRD_PARTY_NOTICES.md",
      "to": "THIRD_PARTY_NOTICES.md"
    },
    {
      "from": "../commons/public",
      "to": "commons/public"
    },
    {
      "from": "../commons/server",
      "to": "commons/server"
    },
    {
      "from": "resources/python",
      "to": "python",
      "filter": ["**/*", "!.deps-installed"]
    }
  ],
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "include": "installer.nsh"
  },
  "win": {
    "target": ["nsis"]
  }
}
