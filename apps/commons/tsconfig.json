{
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/**/*.json",
    "src/types/**/*.d.ts",
    "./package.json",
    "./.env-cmdrc.js"
  ],
  "exclude": ["node_modules", "server", "public", "**/*.test.ts", "**/*.test.tsx"],
  "ts-node": {
    "files": true,
    "compilerOptions": {
      "lib": ["esnext"],
      "module": "commonjs",
      "target": "ESNext",
      "types": ["node", "esnext"]
    }
  },
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": false,
    "incremental": true,
    "inlineSources": false,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "dist",
    "paths": {
      "@cwrc/leafwriter-validator": ["../../packages/cwrc-leafwriter-validator/src/index.worker.ts"],
      "@src/*": ["src/*"]
    },
    "preserveWatchOutput": true,
    "resolveJsonModule": true,
    "strict": true,
    "target": "ESNext",
    "types": ["node", "react", "react-dom"]
  }
}
