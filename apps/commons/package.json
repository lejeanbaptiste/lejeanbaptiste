{
  "name": "leafwriter-commons",
  "version": "3.7.3",
  "private": true,
  "description": "xml editing and rdf annotation using github as document store",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "clean": "rimraf -rf .turbo node_modules public server",
    "build": "npm run build:webpack && npm run build:server",
    "dev": "npm run dev:webpack & npm run build:server:dev -- --onSuccess \"npm run start:dev\"",
    "dev-worker": "npm run dev:webpack-worker-dev & npm run build:server:dev -- --onSuccess \"npm run start:dev\"",
    "build:webpack": "env-cmd -e production webpack",
    "dev:webpack": "env-cmd -e development webpack",
    "dev:webpack-worker-dev": "env-cmd -e development-worker-dev webpack",
    "build:server": "env-cmd -e production tsup",
    "build:server:dev": "env-cmd -e development tsup",
    "start": "env-cmd -e production node --watch server/index.mjs",
    "start:dev": "env-cmd -e development node --watch server/index.mjs"
  },
  "dependencies": {
    "@analytics/cookie-utils": "^0.2.12",
    "@analytics/google-analytics": "^1.1.0",
    "@cwrc/leafwriter": "*",
    "@cwrc/leafwriter-storage-service": "*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/lato": "^5.2.6",
    "@lincs.project/auth-api-contract": "^1.2.1",
    "@mui/icons-material": "^7.1.2",
    "@mui/lab": "^7.0.0-beta.14",
    "@mui/material": "^7.1.2",
    "@octokit/rest": "^22.0.0",
    "@ts-rest/core": "^3.52.1",
    "analytics": "^0.8.16",
    "axios": "^1.10.0",
    "broadcast-channel": "^7.1.0",
    "chroma-js": "^3.1.2",
    "compression": "^1.8.0",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "env-cmd": "^10.1.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "helmet": "^8.1.0",
    "i18next": "^25.2.1",
    "i18next-browser-languagedetector": "^8.2.0",
    "jotai": "^2.12.5",
    "js-cookie": "^3.0.5",
    "keycloak-js": "^26.2.0",
    "kleur": "^4.1.5",
    "loglevel": "^1.9.2",
    "material-ui-popup-state": "^5.3.6",
    "md5": "^2.3.0",
    "mdi-material-ui": "^7.9.4",
    "motion": "^12.19.2",
    "mui-modal-provider": "^2.4.6",
    "notistack": "^3.0.2",
    "overmind": "^28.0.4",
    "overmind-react": "^29.0.6",
    "query-string": "^9.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.5.3",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.6.3",
    "react-scan": "^0.3.4",
    "react-use": "^17.6.0",
    "rxjs": "^7.8.2",
    "swr": "^2.3.3",
    "uuid": "^11.1.0",
    "vanilla-cookieconsent": "^2.9.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@octokit/types": "^14.1.0",
    "@types/chroma-js": "^3.1.1",
    "@types/compression": "^1.8.1",
    "@types/dotenv-webpack": "^7.0.8",
    "@types/express": "^4.17.23",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.15.33",
    "@types/react-dom": "^18.3.7",
    "@types/webpack": "^5.28.5",
    "@types/webpack-env": "^1.18.8",
    "@types/webpackbar": "^5.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "esbuild-loader": "^4.3.0",
    "eslint": "^8.57.1",
    "eslint-config-custom": "*",
    "html-webpack-plugin": "^5.6.3",
    "less": "^4.3.0",
    "less-loader": "^12.3.0",
    "mini-css-extract-plugin": "^2.9.2",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "process": "^0.11.10",
    "rimraf": "^6.0.1",
    "svg-inline-loader": "^0.8.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1",
    "webpackbar": "^7.0.0"
  }
}
