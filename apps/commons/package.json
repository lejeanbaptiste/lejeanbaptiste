{
  "name": "leafwriter-commons",
  "version": "3.6.0",
  "private": true,
  "description": "xml editing and rdf annotation using github as document store",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "clean": "rimraf -rf .turbo node_modules public server",
    "build": "npm run clean && npm run build:webpack && npm run build:server",
    "dev": "npm run dev:webpack & npm run build:server:dev -- --onSuccess \"npm run start:dev\"",
    "dev-worker": "npm run dev:webpack-worker-dev & npm run build:server:dev -- --onSuccess \"npm run start:dev\"",
    "build:webpack": "env-cmd -e production webpack",
    "dev:webpack": "env-cmd -e development webpack",
    "dev:webpack-worker-dev": "env-cmd -e development-worker-dev webpack",
    "build:server": "env-cmd -e production tsup",
    "build:server:dev": "env-cmd -e development tsup",
    "start": "env-cmd -e production node --watch server/index.mjs",
    "start:dev": "env-cmd -e development node --watch server/index.mjs"
  },
  "dependencies": {
    "@analytics/cookie-utils": "^0.2.12",
    "@analytics/google-analytics": "^1.0.7",
    "@cwrc/leafwriter": "*",
    "@cwrc/leafwriter-storage-service": "*",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@fontsource/lato": "^5.0.21",
    "@lincs.project/auth-api-contract": "^1.2.1",
    "@mui/icons-material": "^5.16.7",
    "@mui/lab": "^5.0.0-alpha.173",
    "@mui/material": "^5.16.7",
    "@octokit/rest": "^20.1.1",
    "@ts-rest/core": "^3.49.3",
    "analytics": "^0.8.14",
    "axios": "^1.7.3",
    "broadcast-channel": "^7.0.0",
    "chroma-js": "^2.6.0",
    "compression": "^1.7.4",
    "date-fns": "^3.6.0",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "env-cmd": "^10.1.0",
    "express": "^4.19.2",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.3.24",
    "helmet": "^7.1.0",
    "i18next": "^23.12.3",
    "i18next-browser-languagedetector": "^8.0.0",
    "jotai": "^2.9.2",
    "js-cookie": "^3.0.5",
    "keycloak-js": "^25.0.2",
    "kleur": "^4.1.5",
    "loglevel": "^1.9.1",
    "material-ui-popup-state": "^5.1.2",
    "md5": "^2.3.0",
    "mdi-material-ui": "^7.9.1",
    "mui-modal-provider": "^2.4.2",
    "notistack": "^3.0.1",
    "overmind": "^28.0.3",
    "overmind-react": "^29.0.5",
    "query-string": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.0.1",
    "react-icons": "^5.2.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.0",
    "react-use": "^17.5.1",
    "rxjs": "^7.8.1",
    "swr": "^2.2.5",
    "uuid": "^10.0.0",
    "vanilla-cookieconsent": "^2.9.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@octokit/types": "^13.5.0",
    "@types/chroma-js": "^2.4.4",
    "@types/compression": "^1.7.5",
    "@types/dotenv-webpack": "^7.0.7",
    "@types/express": "^4.17.21",
    "@types/md5": "^2.3.5",
    "@types/node": "^22.2.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack": "^5.28.5",
    "@types/webpack-env": "^1.18.5",
    "@types/webpackbar": "^4.0.6",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.0",
    "esbuild-loader": "^4.2.2",
    "eslint": "^8.57.0",
    "eslint-config-custom": "*",
    "html-webpack-plugin": "^5.6.0",
    "less": "^4.2.0",
    "less-loader": "^12.2.0",
    "mini-css-extract-plugin": "^2.9.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
