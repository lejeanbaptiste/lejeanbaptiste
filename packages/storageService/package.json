{
  "name": "@cwrc/leafwriter-storage-service",
  "version": "0.2.9",
  "description": "storage service for leaf-writer",
  "keywords": [
    "storage",
    "cloud",
    "github",
    "gitlab"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "exports": {
    ".": {
      "import": [
        "./src/index.tsx",
        "./lib/index.js"
      ],
      "require": "./dist/index.js"
    },
    "./Dialog": {
      "import": [
        "./src/StorageDialog.tsx",
        "./lib/StorageDialog.js"
      ],
      "require": "./dist/StorageDialog.js"
    },
    "./headless": {
      "import": [
        "./src/headless.ts",
        "./lib/headless.js"
      ],
      "require": "./dist/headless.js"
    }
  },
  "types": "lib/index.d.ts",
  "module": "src/index.tsx",
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "npm run clean && tsc && webpack",
    "build_es6": "npm run clean && tsc && tsc -m es6 --outDir lib-esm && webpack",
    "clean": "shx rm -rf dist lib lib-esm",
    "test": "jest",
    "test-watch": "jest --watchAll --verbose"
  },
  "dependencies": {
    "@emotion/react": "^11.8.2",
    "@emotion/styled": "^11.8.1",
    "@mui/base": "^5.0.0-alpha.74",
    "@mui/icons-material": "^5.5.1",
    "@mui/lab": "^5.0.0-alpha.75",
    "@mui/material": "^5.5.3",
    "@octokit/rest": "^18.12.0",
    "autosuggest-highlight": "^3.2.1",
    "axios": "^0.26.1",
    "buffer": "^6.0.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^6.2.8",
    "i18next": "^21.6.14",
    "lodash": "^4.17.21",
    "mdi-material-ui": "^7.2.0",
    "overmind": "^28.0.1",
    "overmind-react": "^29.0.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-dropzone": "^12.0.4",
    "react-i18next": "^11.16.2",
    "react-use": "^17.3.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.3",
    "@testing-library/react": "^12.1.3",
    "@testing-library/user-event": "^13.5.0",
    "@types/autosuggest-highlight": "^3.2.0",
    "@types/file-saver": "^2.0.5",
    "@types/lodash": "^4.14.181",
    "@typescript-eslint/eslint-plugin": "^5.17.0",
    "@typescript-eslint/parser": "^5.17.0",
    "clean-webpack-plugin": "^4.0.0",
    "esbuild-loader": "^2.18.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.29.4",
    "mini-css-extract-plugin": "^2.6.0",
    "shx": "^0.3.4",
    "webpack": "^5.71.0",
    "webpackbar": "^5.0.2"
  }
}
