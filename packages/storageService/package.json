{
  "name": "@cwrc/leafwriter-storage-service",
  "version": "1.1.2",
  "description": "storage service for leaf-writer",
  "keywords": [
    "storage",
    "cloud",
    "github",
    "gitlab"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "exports": {
    ".": {
      "import": [
        "./src/index.tsx",
        "./lib/index.js"
      ],
      "require": "./dist/index.js"
    },
    "./Dialog": {
      "import": [
        "./src/StorageDialog.tsx",
        "./lib/StorageDialog.js"
      ],
      "require": "./dist/StorageDialog.js"
    },
    "./headless": {
      "import": [
        "./src/headless.ts",
        "./lib/headless.js"
      ],
      "require": "./dist/headless.js"
    }
  },
  "types": "lib/index.d.ts",
  "module": "src/index.tsx",
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "build": "npm run clean && tsc && webpack",
    "build_es6": "npm run clean && tsc && tsc -m es6 --outDir lib-esm && webpack",
    "build-documentation": "typedoc --out docs src/index.tsx",
    "clean": "shx rm -rf dist lib lib-esm",
    "test": "DEBUG_PRINT_LIMIT=40000 jest",
    "test-watch": "jest --watchAll --verbose",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.10.4",
    "@emotion/styled": "^11.10.4",
    "@mui/base": "^5.0.0-alpha.98",
    "@mui/icons-material": "^5.10.6",
    "@mui/lab": "^5.0.0-alpha.100",
    "@mui/material": "^5.10.6",
    "@octokit/rest": "^19.0.4",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^0.27.2",
    "buffer": "^6.0.3",
    "date-fns": "^2.29.3",
    "file-saver": "^2.0.5",
    "framer-motion": "^7.3.6",
    "i18next": "^21.9.2",
    "lodash": "^4.17.21",
    "loglevel": "^1.8.0",
    "mdi-material-ui": "^7.5.0",
    "mui-modal-provider": "^2.1.0",
    "overmind": "^28.0.2",
    "overmind-react": "^29.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.2",
    "react-i18next": "^11.18.6",
    "react-use": "^17.4.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/autosuggest-highlight": "^3.2.0",
    "@types/file-saver": "^2.0.5",
    "@types/jest": "^29.0.3",
    "@types/lodash": "^4.14.185",
    "@types/mocha": "^9.1.1",
    "@types/testing-library__jest-dom": "^5.14.5",
    "@typescript-eslint/eslint-plugin": "^5.38.0",
    "@typescript-eslint/parser": "^5.38.0",
    "clean-webpack-plugin": "^4.0.0",
    "esbuild-loader": "^2.20.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-react": "^7.31.8",
    "jest-environment-jsdom": "^29.0.3",
    "mini-css-extract-plugin": "^2.6.1",
    "process": "^0.11.10",
    "shx": "^0.3.4",
    "ts-jest": "^29.0.1",
    "webpack": "^5.74.0",
    "webpackbar": "^5.0.2"
  }
}
