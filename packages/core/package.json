{
  "name": "@cwrc/leafwriter",
  "version": "1.0.11",
  "description": "intuitive document editing with xml and rdf",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "contributors": [
    "Andrew MacDonald <andrewjames.code@gmail.com>",
    "James Chartrand <jc.chartrand@gmail.com>"
  ],
  "types": "lib/index.d.ts",
  "module": "src/index.tsx",
  "files": [
    "bin",
    "dist",
    "lib",
    "src",
    "images",
    "css"
  ],
  "scripts": {
    "build": "npm run clean && tsc && webpack && npm run copy-assets",
    "build_es6": "npm run clean && tsc && tsc -m es6 --outDir lib-esm && webpack && npm run copy-validator-worker",
    "copy-assets": "npm run copy-assets_images && npm run copy-assets_editor_css && npm run copy-assets_tinymce_skin",
    "copy-assets_images": "shx cp -r ./src/images ./images",
    "copy-assets_editor_css": "shx mkdir css && shx cp -r ./src/css/build/editor.css ./css",
    "copy-assets_tinymce_skin": "shx mkdir -p ./css/tinymce/skins && shx cp -r ./src/css/tinymce/**/* ./css/tinymce/skins/",
    "clean": "shx rm -rf dist lib lib-esm css images"
  },
  "dependencies": {
    "@cwrc/leafwriter-validator": "^0.4.2",
    "@dnd-kit/core": "^5.0.1",
    "@dnd-kit/modifiers": "^5.0.0",
    "@dnd-kit/sortable": "^6.0.0",
    "@emotion/react": "^11.7.1",
    "@emotion/styled": "^11.6.0",
    "@fontsource/lato": "^4.5.1",
    "@fortawesome/fontawesome-free": "^6.0.0",
    "@mui/icons-material": "^5.4.2",
    "@mui/lab": "^5.0.0-alpha.69",
    "@mui/material": "^5.4.2",
    "axios": "^0.26.0",
    "chroma-js": "^2.4.2",
    "comlink": "^4.3.1",
    "css": "^3.0.0",
    "css-tooltip": "^0.3.4",
    "formik": "^2.2.9",
    "framer-motion": "^6.2.6",
    "fscreen": "^1.2.0",
    "i18next": "^21.6.11",
    "iso-639-2": "^3.0.1",
    "jquery": "^3.6.0",
    "jquery-ui": "^1.13.1",
    "js-cookie": "^3.0.1",
    "jstree": "^3.3.12",
    "layout-jquery3": "^1.8.5",
    "lodash": "^4.17.21",
    "luxon": "^2.3.0",
    "mdi-material-ui": "^7.1.0",
    "monaco-editor": "^0.32.1",
    "notistack": "^2.0.3",
    "openseadragon": "^3.0.0",
    "overmind": "^28.0.1",
    "overmind-react": "^29.0.1",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.27.0",
    "progressbar.js": "^1.1.0",
    "rdflib": "^2.2.17",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-i18next": "^11.15.4",
    "react-intersection-observer": "^8.33.1",
    "react-transition-group": "^4.4.2",
    "react-use": "^17.3.2",
    "tinymce": "^5.10.3",
    "uuid": "^8.3.2",
    "wikidata-sdk": "^7.14.2",
    "yup": "^0.32.11"
  },
  "devDependencies": {
    "@types/chroma-js": "^2.1.3",
    "@types/css": "^0.0.33",
    "@types/fscreen": "^1.0.1",
    "@types/jquery": "^3.5.13",
    "@types/jqueryui": "^1.12.16",
    "@types/js-cookie": "^3.0.1",
    "@types/jstree": "^3.3.41",
    "@types/luxon": "^2.0.9",
    "@types/node": "^17.0.18",
    "@types/openseadragon": "^3.0.0",
    "@types/prismjs": "^1.26.0",
    "@types/progressbar.js": "^1.1.2",
    "@types/react-dom": "^17.0.11",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "clean-webpack-plugin": "^4.0.0",
    "esbuild-loader": "^2.18.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-react": "^7.28.0",
    "mini-css-extract-plugin": "^2.5.3",
    "monaco-editor-webpack-plugin": "^7.0.1",
    "shx": "^0.3.4",
    "webpack": "^5.69.1",
    "webpackbar": "^5.0.2"
  }
}
