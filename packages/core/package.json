{
  "name": "@cwrc/leafwriter",
  "version": "1.2.0",
  "description": "intuitive document editing with xml and rdf",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "contributors": [
    "Andrew MacDonald <andrewjames.code@gmail.com>",
    "James Chartrand <jc.chartrand@gmail.com>"
  ],
  "types": "lib/index.d.ts",
  "module": "src/index.tsx",
  "files": [
    "bin",
    "dist",
    "lib",
    "src"
  ],
  "scripts": {
    "build": "npm run clean && tsc && webpack && npm run release-copy-assets",
    "build_es6": "npm run clean && tsc && tsc -m es6 --outDir lib-esm && webpack && npm run release-copy-assets",
    "build-documentation": "typedoc --out docs src/index.tsx",
    "release-copy-assets": "ts-node release.ts",
    "clean": "shx rm -rf dist lib lib-esm",
    "test": "jest",
    "cm": "git-cz",
    "prepublishOnly": "npm run build"
  },
