    "css-tooltip": "^0.3.4",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "formik": "^2.4.9",
    "fscreen": "^1.2.0",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^25.8.14",
