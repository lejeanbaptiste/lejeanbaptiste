    "css": "^3.0.0",
    "css-tooltip": "^0.3.4",
    "dexie": "^3.2.4",
    "dexie-react-hooks": "^1.1.7",
    "formik": "^2.4.5",
    "framer-motion": "^10.16.9",
    "fscreen": "^1.2.0",
    "html2canvas": "^1.4.1",
    "i18next": "^23.7.7",
    "iso-639-2": "^3.0.2",
    "jotai": "^2.6.0",
    "jquery": "^3.7.1",
    "jquery-ui": "^1.13.2",
    "js-cookie": "^3.0.5",
    "layout-jquery3": "^1.8.5",
