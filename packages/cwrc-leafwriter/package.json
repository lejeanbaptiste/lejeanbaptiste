    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@fontsource/lato": "^5.0.17",
    "@fortawesome/fontawesome-free": "^6.5.1",
    "@mui/icons-material": "^5.14.19",
    "@mui/material": "^5.14.19",
    "@reactivex/rxjs": "^6.6.7",
    "axios": "^1.6.2",
    "chroma-js": "^2.4.2",
