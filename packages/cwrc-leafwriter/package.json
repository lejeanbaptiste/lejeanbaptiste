{
  "name": "@cwrc/leafwriter",
  "version": "3.6.0",
  "description": "intuitive document editing with xml and rdf",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "contributors": [
    "Andrew MacDonald <andrewjames.code@gmail.com>",
    "James Chartrand <jc.chartrand@gmail.com>"
  ],
  "exports": {
    ".": {
      "import": [
        "./src/index.tsx",
        "./lib/src/index.js"
      ],
      "require": "./dist/index.js"
    }
  },
  "types": "lib/src/index.d.ts",
  "files": [
    "bin",
    "dist",
    "lib",
    "src"
  ],
  "scripts": {
    "build": "NODE_OPTIONS=--max_old_space_size=4096 webpack && npm run release-copy-assets",
    "build-documentation": "typedoc --out docs src/index.tsx",
    "release-copy-assets": "node release.js",
    "clean": "rm -rf node_modules dist lib",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "cm": "git-cz",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cwrc/leafwriter-validator": "^*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/lato": "^5.2.5",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "axios": "^1.8.4",
    "chroma-js": "^3.1.2",
    "classnames": "^2.5.1",
    "comlink": "^4.4.2",
    "css": "^3.0.0",
    "css-tooltip": "^0.3.4",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "formik": "^2.4.6",
    "fscreen": "^1.2.0",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "i18next": "^24.2.3",
    "iso-639-2": "^3.0.2",
    "jotai": "^2.12.2",
    "jotai-devtools": "^0.11.0",
    "jquery": "^3.7.1",
    "jquery-ui": "^1.14.1",
    "js-cookie": "^3.0.5",
    "layout-jquery3": "^1.8.5",
    "lodash": "^4.17.21",
    "loglevel": "^1.9.2",
    "luxon": "^3.6.1",
    "mdi-material-ui": "^7.9.4",
    "monaco-editor": "^0.52.2",
    "motion": "^12.6.3",
    "mui-modal-provider": "^2.4.6",
    "nanoid": "^5.1.5",
    "notistack": "^3.0.2",
    "openseadragon": "^5.0.1",
    "overmind": "^28.0.3",
    "overmind-react": "^29.0.5",
    "progressbar.js": "^1.1.1",
    "rdflib": "^2.2.37",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.1",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.16.0",
    "react-resizable-panels": "^2.1.7",
    "react-virtuoso": "^4.12.6",
    "rxjs": "^7.8.2",
    "tinymce": "5.10.9",
    "uuid": "^11.1.0",
    "zod": "^3.24.2",
    "zod-formik-adapter": "^1.3.0"
  },
  "devDependencies": {
