{
  "extends": "tsconfig/website.json",
  "include": ["**/*.ts", "**/*.tsx", "src/**/*.json", "./package.json", "./.env-cmdrc.js"],
  "exclude": ["node_modules"],
  "ts-node": {
    "files": true,
    "compilerOptions": {
      "lib": ["esnext"],
      "module": "commonjs",
      "target": "ESNext",
      "types": ["node", "esnext"]
    }
  },
  "compilerOptions": {
    "baseUrl": ".",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "@src/*": ["src/*"]
    },
    "outDir": "dist"
  }
}
