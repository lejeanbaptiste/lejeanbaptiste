{
  "extends": "tsconfig/webworker.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules"],
  "ts-node": {
    "files": true,
    "compilerOptions": {
      "lib": ["esnext"],
      "module": "commonjs",
      "target": "ESNext",
      "types": ["node", "jest", "mocha"]
    }
  },
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@src/*": ["src/*"]
    },
    "outDir": "lib",
    "types": ["node", "jest", "mocha"]
  }
}
