{
  "name": "@cwrc/leafwriter-validator",
  "version": "1.2.0",
  "description": "webworker to handle validation on Leaf-Writer",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation",
    "rng validation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "exports": {
    ".": {
      "import": "./src/index.worker",
      "require": "./dist/leafwriter-validator.worker.js"
    }
  },
  "types": "lib/index.worker.d.ts",
  "module": "src/index.worker.ts",
  "scripts": {
    "browserify-jsdom": "browserify -r jsdom -s jsdom -o src/lib/jsdom/jsdom-browserified.js",
    "build": "npm run clean && tsc && webpack",
    "build_es6": "npm run clean && tsc && tsc -m es6 --outDir lib-esm && webpack",
    "clean": "shx rm -rf dist lib lib-esm",
    "test": "jest",
    "test-watch": "jest --watchAll --verbose",
    "build-documentation": "typedoc --out docs src/index.worker.ts",
    "cm": "git-cz",
    "prepublishOnly": "npm test && npm run build_es6"
  },
  "dependencies": {
    "@cwrc/salve-dom-leafwriter": "^6.0.3",
    "@cwrc/salve-leafwriter": "^1.2.2",
    "comlink": "^4.3.1",
    "lodash": "^4.17.21",
    "loglevel": "^1.8.0",
    "lzutf8": "^0.6.3"
  },
  "devDependencies": {
    "@types/jest": "^29.1.2",
    "@types/jsdom": "^20.0.0",
    "@types/lodash": "^4.14.186",
    "@types/mocha": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.40.0",
    "@typescript-eslint/parser": "^5.40.0",
    "browserify": "^17.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "commitizen": "^4.2.5",
    "esbuild-loader": "^2.20.0",
    "eslint": "^8.25.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "git-cz": "^4.9.0",
    "husky": "^8.0.1",
    "jest": "^29.1.2",
    "jest-environment-jsdom": "^29.1.2",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "^20.0.1",
    "prettier": "^2.7.1",
    "shx": "^0.3.4",
    "ts-jest": "^29.0.3",
    "ts-loader": "^9.4.1",
    "typedoc": "^0.23.16",
    "typescript": "^4.8.4",
    "webpack": "^5.74.0",
    "webpack-cli": "^4.10.0",
    "webpackbar": "^5.0.2"
  },
  "peerDependencies": {
    "comlink": "^4.3.1"
  }
}
