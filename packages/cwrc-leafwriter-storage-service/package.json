{
  "name": "@cwrc/leafwriter-storage-service",
  "version": "4.2.0",
  "sideEffects": false,
  "description": "storage service for leaf-writer",
  "keywords": [
    "storage",
    "cloud",
    "github",
    "gitlab"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Daniel Patrick Morgan (CNRS)",
  "exports": {
    ".": {
      "import": [
        "./lib/index.js",
        "./src/index.tsx"
      ],
      "types": "./lib/index.d.ts"
    },
    "./components": {
      "import": [
        "./lib/components/index.js",
        "./src/components/index.ts"
      ],
      "types": "./src/components/index.ts"
    },
    "./db": {
      "import": [
        "./lib/db/index.js",
        "./src/db/index.ts"
      ],
      "types": "./src/db/index.ts"
    },
    "./dialog": {
      "import": [
        "./lib/StorageDialog.js",
        "./src/StorageDialog.tsx"
      ],
      "types": "./lib/StorageDialog.d.ts"
    },
    "./dialogs": {
      "import": [
        "./lib/dialogs/index.js",
        "./src/dialogs/index.ts"
      ],
      "types": "./src/dialogs/index.ts"
    },
    "./headless": {
      "import": [
        "./lib/headless.js",
        "./src/headless.ts"
      ],
      "types": "./lib/headless.d.ts"
    },
    "./i18n": {
      "import": [
        "./lib/i18n.js",
        "./src/i18n.ts"
      ],
      "types": "./src/i18n.ts"
    },
    "./icons": {
      "import": [
        "./lib/icons/index.js",
        "./src/icons/index.tsx"
      ],
      "types": "./src/icons/index.tsx"
    },
    "./overmind": {
      "import": [
        "./lib/overmind/index.js",
        "./src/overmind/index.ts"
      ],
      "types": "./src/overmind/index.ts"
    },
    "./providers/*": {
      "import": [
        "./lib/providers/*.js",
        "./src/providers/*.ts"
      ],
      "types": "./src/providers/*.ts"
    },
    "./types": {
      "import": [
        "./lib/types/index.js",
        "./src/types/index.ts"
      ],
      "types": "./src/types/index.ts"
    },
    "./types/*": {
      "import": [
        "./lib/types/*.js",
        "./src/types/*.ts"
      ],
      "types": "./src/types/*.ts"
    },
    "./utilities": {
      "import": [
        "./lib/utilities/index.js",
        "./src/utilities/index.ts"
      ],
      "types": "./src/utilities/index.ts"
    }
  },
  "types": "lib/index.d.ts",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "files": [
    "lib",
    "headless.d.ts",
    "dialog.d.ts"
  ],
  "scripts": {
    "build": "npm run clean && tsup && tsc --emitDeclarationOnly --declaration",
    "dev": "tsup --watch",
    "clean": "rm -rf node_modules lib coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "test": "DEBUG_PRINT_LIMIT=40000 NODE_OPTIONS=--experimental-vm-modules jest",
    "test-watch": "jest --watchAll --verbose",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@octokit/rest": "^22.0.1",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^1.13.6",
    "buffer": "^6.0.3",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "file-saver": "^2.0.5",
    "i18next": "^25.8.14",
    "lodash": "^4.17.23",
    "loglevel": "^1.9.2",
    "mdi-material-ui": "^7.9.4",
    "motion": "^12.35.0",
    "mui-modal-provider": "^2.4.6",
    "nanoid": "^5.1.6",
    "overmind": "28.0.4",
    "overmind-react": "29.0.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.6.0",
    "react-use": "^17.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/autosuggest-highlight": "^3.2.3",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^8.57.1",
    "eslint-config-custom": "*",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
