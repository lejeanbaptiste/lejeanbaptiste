{
  "name": "@cwrc/leafwriter-storage-service",
  "version": "4.0.0",
  "sideEffects": false,
  "description": "storage service for leaf-writer",
  "keywords": [
    "storage",
    "cloud",
    "github",
    "gitlab"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "exports": {
    ".": {
      "import": [
        "./src/index.tsx",
        "./lib/index.js"
      ],
      "types": "./lib/index.d.ts"
    },
    "./dialog": {
      "import": [
        "./src/StorageDialog.tsx",
        "./lib/StorageDialog.js"
      ],
      "types": "./lib/StorageDialog.d.ts"
    },
    "./headless": {
      "import": [
        "./src/headless.ts",
        "./lib/headless.js"
      ],
      "types": "./lib/headless.d.ts"
    }
  },
  "types": "lib/index.d.ts",
  "main": "./lib/index.js",
  "module": "src/index.tsx",
  "files": [
    "lib",
    "headless.d.ts",
    "dialog.d.ts"
  ],
  "scripts": {
    "build": "npm run clean && tsup && tsc --emitDeclarationOnly --declaration",
    "clean": "rm -rf .turbo node_modules lib coverage",
    "build-documentation": "typedoc --out docs src/index.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "test": "DEBUG_PRINT_LIMIT=40000 jest",
    "test-watch": "jest --watchAll --verbose",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/base": "5.0.0-beta.40",
    "@mui/icons-material": "^5.16.6",
    "@mui/lab": "^5.0.0-alpha.173",
    "@mui/material": "^5.16.6",
    "@octokit/rest": "^20.1.1",
    "autosuggest-highlight": "^3.3.4",
    "axios": "^1.7.3",
    "buffer": "^6.0.3",
    "date-fns": "^3.6.0",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.3.21",
    "i18next": "^23.12.2",
    "lodash": "^4.17.21",
    "loglevel": "^1.9.1",
    "mdi-material-ui": "^7.9.1",
    "mui-modal-provider": "^2.4.2",
    "overmind": "^28.0.3",
    "overmind-react": "^29.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-i18next": "^15.0.0",
    "react-icons": "^5.2.1",
    "react-use": "^17.5.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@octokit/types": "^13.5.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/autosuggest-highlight": "^3.2.3",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.7",
    "@types/mocha": "^10.0.7",
    "@types/node": "^22.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-custom": "*",
    "fake-indexeddb": "^6.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "process": "^0.11.10",
    "shx": "^0.3.4",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.2.4",
    "typedoc": "^0.26.5",
    "typescript": "^5.5.4"
  }
}
