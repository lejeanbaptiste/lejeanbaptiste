{
  "include": ["src/*.ts"],
  "exclude": ["node_modules", "lib"],
  "compilerOptions": {
    "baseUrl": ".",
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": false,
    "isolatedModules": true,
    "lib": ["es2023"],
    "module": "ESNext",
    "moduleResolution": "node",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "lib",
    "paths": {
      "@src/*": ["src/*"]
    },
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"],
    "target": "ESNEXT"
  }
}
