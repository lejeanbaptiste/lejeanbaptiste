{
  "name": "@cwrc/leafwriter-validator",
  "version": "4.4.2",
  "description": "webworker to handle validation on Leaf-Writer",
  "keywords": [
    "xml",
    "rdf",
    "editor",
    "annotation",
    "rng validation"
  ],
  "homepage": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer",
  "bugs": {
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/calincs/cwrc/leaf-writer/leaf-writer.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "GPL-2.0",
  "author": "Luciano Frizzera <lucaju@gmail.com>",
  "exports": {
    ".": {
      "import": [
        "./src/index.worker",
        "./lib/index.worker"
      ],
      "require": "./dist/leafwriter-validator.worker.js"
    }
  },
  "types": "lib/index.worker.d.ts",
  "module": "src/index.worker.ts",
  "files": [
    "dist",
    "lib"
  ],
  "scripts": {
    "browserify-jsdom": "browserify -r jsdom -s jsdom -o src/lib/jsdom/jsdom-browserified.js",
    "build": "npm run clean && tsup && tsc --emitDeclarationOnly --declaration && webpack",
    "clean": "rm -rf .turbo node_modules dist lib docs",
    "format": "prettier --write \"**/*.{ts,md}\"",
    "format-check": "prettier . --check",
    "lint": "eslint .",
    "test": "jest",
    "test-watch": "jest --watchAll --verbose",
    "build-documentation": "typedoc src/index.worker.ts",
    "cm": "git-cz",
    "prepublishOnly": "npm test && npm run build && npm run build-documentation"
  },
  "dependencies": {
    "@cwrc/salve-dom-leafwriter": "^6.0.3",
    "@cwrc/salve-leafwriter": "^1.2.2",
    "comlink": "^4.4.2",
    "dexie": "^4.0.11",
    "lodash": "^4.17.21",
    "loglevel": "^1.9.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.17",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "browserify": "^17.0.1",
    "clean-webpack-plugin": "^4.0.0",
    "esbuild-loader": "^4.3.0",
    "eslint": "^8.57.1",
    "eslint-config-custom": "*",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jsdom": "21.1.2",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typedoc": "^0.28.5",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpackbar": "^7.0.0"
  },
  "peerDependencies": {
    "comlink": "^4.4.2"
  }
}
